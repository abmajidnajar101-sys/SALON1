// Renders an interactive 3D universe with rotating luxurious geometry that moves dynamically with the mouse cursor
const ThreeBackground = () => {
  const containerRef = useRef(null);

  useEffect(() => {
    let scriptLoaded = false;
    let scene, camera, renderer, particles, geometry, coreMesh;
    let mouseX = 0, mouseY = 0;
    let windowHalfX = window.innerWidth / 2;
    let windowHalfY = window.innerHeight / 2;

    const initThree = () => {
      if (!window.THREE) return;

      // Scene setup
      scene = new window.THREE.Scene();
      
      // Camera Setup
      camera = new window.THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 1, 1000);
      camera.position.z = 250;

      // Renderer setup with premium color output
      renderer = new window.THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      
      if (containerRef.current) {
        containerRef.current.appendChild(renderer.domElement);
      }

      // Add elegant particle constellation representing luxury starry night
      const particleCount = 250;
      const particleGeometry = new window.THREE.BufferGeometry();
      const positions = new Float32Array(particleCount * 3);
      const colors = new Float32Array(particleCount * 3);

      for (let i = 0; i < particleCount * 3; i += 3) {
        // Starry ring distribution
        const angle = Math.random() * Math.PI * 2;
        const radius = 150 + Math.random() * 200;
        positions[i] = Math.cos(angle) * radius;
        positions[i + 1] = (Math.random() - 0.5) * 300;
        positions[i + 2] = Math.sin(angle) * radius;

        // Golden premium particles colors
        colors[i] = 1.0;                     // R: high
        colors[i + 1] = 0.7 + Math.random() * 0.25; // G: gold tone
        colors[i + 2] = 0.0 + Math.random() * 0.15; // B: golden yellow
      }

      particleGeometry.setAttribute('position', new window.THREE.BufferAttribute(positions, 3));
      particleGeometry.setAttribute('color', new window.THREE.BufferAttribute(colors, 3));

      // Create glowing round points for particles
      const pMaterial = new window.THREE.PointsMaterial({
        size: 2.2,
        vertexColors: true,
        transparent: true,
        opacity: 0.7,
        blending: window.THREE.AdditiveBlending
      });

      particles = new window.THREE.Points(particleGeometry, pMaterial);
      scene.add(particles);

      // Create a gorgeous central glowing rotating luxury abstract wireframe
      // This represents luxury diamond/crown shears structural design
      const coreGeometry = new window.THREE.IcosahedronGeometry(60, 1);
      const coreMaterial = new window.THREE.MeshBasicMaterial({
        color: 0xD4AF37, // Metallic Gold
        wireframe: true,
        transparent: true,
        opacity: 0.15,
        blending: window.THREE.AdditiveBlending
      });
      coreMesh = new window.THREE.Mesh(coreGeometry, coreMaterial);
      scene.add(coreMesh);

      // Light lighting setup
      const ambientLight = new window.THREE.AmbientLight(0xffffff, 0.4);
      scene.add(ambientLight);

      // Event Listeners
      document.addEventListener('mousemove', onDocumentMouseMove);
      window.addEventListener('resize', onWindowResize);

      animate();
    };

    const onDocumentMouseMove = (event) => {
      mouseX = (event.clientX - windowHalfX) * 0.25;
      mouseY = (event.clientY - windowHalfY) * 0.25;
    };

    const onWindowResize = () => {
      windowHalfX = window.innerWidth / 2;
      windowHalfY = window.innerHeight / 2;
      if (camera && renderer) {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      }
    };

    const animate = () => {
      if (!renderer || !scene || !camera) return;
      requestAnimationFrame(animate);

      // Smooth camera interpolation based on mouse
      camera.position.x += (mouseX - camera.position.x) * 0.05;
      camera.position.y += (-mouseY - camera.position.y) * 0.05;
      camera.lookAt(scene.position);

      // Rotate premium core mesh and particle background elegantly
      if (coreMesh) {
        coreMesh.rotation.x += 0.003;
        coreMesh.rotation.y += 0.004;
      }

      if (particles) {
        particles.rotation.y += 0.001;
        particles.rotation.x += 0.0005;
      }

      renderer.render(scene, camera);
    };

    // Load ThreeJS from CDN
    const existingScript = document.getElementById('threejs-cdn');
    if (!existingScript) {
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
      script.id = 'threejs-cdn';
      script.async = true;
      script.onload = () => {
        scriptLoaded = true;
        initThree();
      };
      document.body.appendChild(script);
    } else {
      if (window.THREE) {
        initThree();
      } else {
        existingScript.addEventListener('load', initThree);
      }
    }

    return () => {
      document.removeEventListener('mousemove', onDocumentMouseMove);
      window.removeEventListener('resize', onWindowResize);
      if (containerRef.current && renderer && renderer.domElement) {
        containerRef.current.removeChild(renderer.domElement);
      }
    };
  }, []);

  return <div ref={containerRef} className="fixed inset-0 pointer-events-none z-0 overflow-hidden" />;
};

const BeforeAfterSlider = () => {
  const [sliderPosition, setSliderPosition] = useState(50);
  const containerRef = useRef(null);

  const handleMove = (clientX) => {
    if (!containerRef.current) return;
    const rect = containerRef.current.getBoundingClientRect();
    const x = clientX - rect.left;
    const percentage = Math.max(0, Math.min(100, (x / rect.width) * 100));
    setSliderPosition(percentage);
  };

  const handleMouseMove = (e) => {
    handleMove(e.clientX);
  };

  const handleTouchMove = (e) => {
    if (e.touches && e.touches[0]) {
      handleMove(e.touches[0].clientX);
    }
  };

  return (
    <div className="w-full max-w-4xl mx-auto px-4 my-16">
      <div className="text-center mb-8">
        <span className="text-amber-500 font-semibold tracking-widest text-xs uppercase block mb-2">Transformations</span>
        <h2 className="text-3xl md:text-5xl font-serif font-bold text-white">Visual Artistry Redefined</h2>
        <p className="text-neutral-400 max-w-lg mx-auto mt-2 text-sm">
          Slide the handle to view the precision makeover and detailing results of our premium hair craftsmanship.
        </p>
      </div>

      <div 
        ref={containerRef}
        onMouseMove={handleMouseMove}
        onTouchMove={handleTouchMove}
        className="relative h-[350px] md:h-[500px] w-full rounded-2xl overflow-hidden border border-neutral-800 cursor-ew-resize select-none shadow-2xl"
