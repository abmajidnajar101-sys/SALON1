            clipPath: `polygon(0 0, ${sliderPosition}% 0, ${sliderPosition}% 100%, 0 100%)`
          }}
        >
          <div className="absolute bottom-4 right-4 bg-amber-500 text-black px-3 py-1 rounded-md text-xs uppercase font-bold tracking-wider shadow-lg">
            After Signature Cut
          </div>
        </div>

        {/* SLIDER HANDLE LINE */}
        <div 
          className="absolute top-0 bottom-0 w-1 bg-amber-500 cursor-ew-resize shadow-[0_0_15px_rgba(255,179,0,0.8)]"
          style={{ left: `${sliderPosition}%` }}
        >
          {/* HANDLE ICON */}
          <div className="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-10 h-10 rounded-full bg-amber-500 text-black border-4 border-neutral-950 flex items-center justify-center shadow-lg pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" strokeWidth={2.5} stroke="currentColor" className="w-5 h-5">
              <path strokeLinecap="round" strokeLinejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  );
